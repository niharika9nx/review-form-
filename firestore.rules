rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: Only niharikachinimilli9@gmail.com is admin for now
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'niharikachinimilli9@gmail.com' &&
        request.auth.token.email_verified == true
      );
    }

    // Review Validation
    function isValidReview(data) {
      return data.keys().hasAll(['name', 'year', 'branch', 'review', 'rating', 'timestamp']) &&
             data.name is string && data.name.size() >= 2 &&
             data.year is string &&
             data.branch is string &&
             data.review is string && data.review.size() >= 20 &&
             // Allow any number type for rating
             (data.rating is int || data.rating is float || data.rating >= 0) &&
             data.rating >= 1 && data.rating <= 5 &&
             // Relax timestamp check to 1 hour tolerance for extreme clock drift
             (data.timestamp is int || data.timestamp is float || data.timestamp > 0) && 
             Math.abs(data.timestamp - request.time.toMillis()) < 3600000;
    }

    match /reviews/{reviewId} {
      allow read: if true; 
      allow create: if true; // Temporarily allow all creates to verify connection, then tighten
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
